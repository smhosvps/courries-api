<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes">
    <title>Password Reset – Courries</title>
    <style>
        /* Base reset & email‑safe styles */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        /* Responsive rules for mobile devices */
        @media only screen and (max-width: 600px) {
            .responsive-container {
                width: 100% !important;
                max-width: 100% !important;
            }
            .inner-padding {
                padding: 28px 20px !important;
            }
            .otp-code {
                font-size: 30px !important;
                letter-spacing: 2px !important;
                word-break: break-word !important;
            }
            .brand-logo {
                font-size: 26px !important;
                letter-spacing: 1.5px !important;
            }
            h1 {
                font-size: 26px !important;
                line-height: 1.3 !important;
            }
            .body-text {
                font-size: 15px !important;
                line-height: 1.5 !important;
            }
            .validity-badge {
                font-size: 13px !important;
                padding: 6px 14px !important;
            }
            .btn-primary {
                display: block !important;
                width: 100% !important;
                padding: 14px 20px !important;
                font-size: 16px !important;
            }
            .otp-box {
                padding: 18px 12px !important;
                margin-bottom: 22px !important;
            }
            .footer-text-sm {
                font-size: 11px !important;
            }
        }
        /* Extra small screens (≤480px) */
        @media only screen and (max-width: 480px) {
            .inner-padding {
                padding: 22px 16px !important;
            }
            .otp-code {
                font-size: 28px !important;
                letter-spacing: 1px !important;
            }
            h1 {
                font-size: 24px !important;
            }
        }
        /* Outlook / legacy compatibility */
        .ExternalClass, .ReadMsgBody {
            width: 100%;
            background-color: #f4f7fc;
        }
        table, td {
            border-collapse: collapse;
            mso-table-lspace: 0pt;
            mso-table-rspace: 0pt;
        }
        img, a {
            border: 0;
            outline: none;
            text-decoration: none;
        }
    </style>
</head>
<body style="margin: 0; padding: 0; font-family: 'Segoe UI', 'Helvetica Neue', Helvetica, Arial, sans-serif; background-color: #f4f8fc; color: #1e2a3e; width: 100%; -webkit-font-smoothing: antialiased;">
    
    <!-- MAIN WRAPPER: 100% background -->
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" align="center" style="background-color: #f4f8fc; width: 100%;">
        <tr>
            <td align="center" style="padding: 25px 16px;">
                <!-- CARD CONTAINER: max-width 600px, responsive -->
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" align="center" style="max-width: 600px; width: 100%; margin: 0 auto; background-color: #ffffff; border-radius: 28px; overflow: hidden; box-shadow: 0 12px 28px rgba(0, 0, 0, 0.06); border: 1px solid #e2e8f0;">
                    
                    <!-- MAIN CONTENT ROW (password reset OTP) -->
                    <tr>
                        <td class="inner-padding" style="padding: 44px 36px 36px 36px; background-color: #ffffff;">
                            
                            <!-- Brand header (text logo, consistent with Courries identity) -->
                            <div class="brand-logo" style="font-size: 30px; font-weight: 800; color: #0f6e7c; margin-bottom: 24px; text-transform: uppercase; letter-spacing: 2.5px; font-family: inherit; text-align: center;">
                                COURRIES
                            </div>
                            
                            <!-- Password reset heading -->
                            <h1 style="font-size: 30px; font-weight: 700; color: #1e2f3a; margin: 0 0 18px 0; text-align: center; line-height: 1.25;">Reset Your Password</h1>
                            
                            <!-- Instruction text (strictly OTP) -->
                            <p class="body-text" style="font-size: 16px; line-height: 1.55; color: #33475b; margin-bottom: 28px; text-align: center;">
                                Enter the verification code below to confirm your identity and create a new password for your <strong>Courries</strong> account.
                            </p>
                            
                            <!-- OTP BOX (urgent style, same as account verification) -->
                            <div class="otp-box" style="background-color: #fff6f0; border-radius: 20px; padding: 26px 16px; margin-bottom: 26px; border: 1.5px solid #e25c3a; text-align: center; box-shadow: 0 3px 8px rgba(226,92,58,0.08);">
                                <p class="otp-code" style="font-size: 40px; font-weight: 800; margin: 0; letter-spacing: 6px; color: #e25c3a; font-family: 'Courier New', 'SF Mono', monospace; word-break: break-word; line-height: 1.2;">
                                    <%= otp %>
                                </p>
                                <p style="font-size: 12px; color: #b05c3a; margin: 14px 0 0 0; text-transform: uppercase; letter-spacing: 1.2px; font-weight: 500;">password reset code</p>
                            </div>
                            
                            <!-- Validity notice (urgent, time‑sensitive) -->
                            <p class="validity-badge" style="font-size: 14px; color: #c9421f; margin-bottom: 32px; text-align: center; font-weight: 600; background-color: #fff0eb; padding: 8px 16px; border-radius: 40px; display: inline-block; width: auto; margin-left: auto; margin-right: auto;">
                                ⏱️ This code expires in <strong>5 minutes</strong> – do not share it with anyone.
                            </p>
                            
                            <!-- Action button: back to login / app (responsive) -->
                            <div style="text-align: center; margin-bottom: 32px;">
                                <a href="#" class="btn-primary" style="display: inline-block; background-color: #0f6e7c; color: #ffffff; text-decoration: none; font-weight: 700; font-size: 16px; padding: 12px 32px; border-radius: 60px; transition: background 0.2s ease; font-family: inherit; text-align: center; border: none; box-shadow: 0 2px 6px rgba(15,110,124,0.2);">
                                    ← Back to Sign In
                                </a>
                            </div>
                            
                            <!-- Security note (OTP restriction & safety) -->
                            <p style="font-size: 12.5px; line-height: 1.45; color: #6c7e8f; text-align: center; margin: 12px 0 18px 0; border-top: 1px solid #eef2f7; padding-top: 22px;">
                                🔒 If you did not request a password reset, please ignore this email. Your account remains secure.
                            </p>
                            
                            <!-- Support contact (minimal, helpful) -->
                            <div style="text-align: center; margin-top: 6px;">
                                <p style="font-size: 13px; color: #4a627a; margin-bottom: 6px;">Need assistance? Contact our support team:</p>
                                <p style="margin: 0;">
                                    <a href="mailto:support@courries.com" style="color: #0f6e7c; text-decoration: none; font-weight: 600; font-size: 14px;">support@courries.com</a>
                                </p>
                            </div>
                            
                        </td>
                    </tr>
                    
                    <!-- FOOTER (clean, non‑promotional, OTP context) -->
                    <tr>
                        <td style="padding: 20px 30px 26px 30px; background-color: #fafefd; border-top: 1px solid #e2edf2; text-align: center;">
                            <p style="font-size: 18px; font-weight: 700; color: #0b5e6b; margin: 0 0 12px 0; letter-spacing: 1px;">Courries</p>
                            <p style="font-size: 12px; color: #7d8e9f; margin: 0 0 8px 0; line-height: 1.4;">
                                Secure password reset · One‑time passcode
                            </p>
                            <p style="font-size: 11px; color: #94a3b3; margin: 0;">
                                &copy; <%= new Date().getFullYear() %> Courries. All rights reserved.
                            </p>
                            <p style="font-size: 11px; color: #94a3b3; margin-top: 12px;">
                                Your privacy is our priority. This code is strictly for resetting your password.
                            </p>
                        </td>
                    </tr>
                </table>
                <!-- end main card -->
            </td>
        </tr>
    </table>
    <!-- end wrapper -->
</body>
</html>